---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  author: string;
  image?: string;
}

const { title, description, pubDate, updatedDate, category, tags, author, image } = Astro.props;

// Get related posts (same category, excluding current)
const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const relatedPosts = allPosts
  .filter(p => p.data.category === category)
  .slice(0, 3);

// Fallback to recent posts if no related
const fallbackPosts = relatedPosts.length > 0 ? relatedPosts : allPosts.slice(0, 3);

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  publisher: {
    '@type': 'Organization',
    name: '里爾家具研究室',
    url: 'https://realfurniture.tw',
  },
  ...(image ? { image: `https://realfurniture.tw${image}` } : {}),
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={Astro.url.href}
  ogImage={image}
  article={{
    publishedTime: pubDate.toISOString(),
    modifiedTime: (updatedDate ?? pubDate).toISOString(),
    author,
    tags,
  }}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} slot="head" />

  <!-- Article Hero -->
  <section class="article-hero">
    <div class="container-narrow">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="麵包屑導航">
        <a href="/" class="breadcrumb-link">首頁</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <a href="/blog" class="breadcrumb-link">文章</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <a href={`/categories/${category}`} class="breadcrumb-link">{category}</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <span class="breadcrumb-current">{title}</span>
      </nav>

      <!-- Meta tags -->
      <div class="article-meta-top">
        <a href={`/categories/${category}`} class="tag tag-wood">{category}</a>
        {tags.map(tag => (
          <span class="tag">#{tag}</span>
        ))}
      </div>

      <!-- Title -->
      <h1 class="article-title">{title}</h1>

      <!-- Author & Date -->
      <p class="article-byline">
        <span class="article-author">{author}</span>
        <span class="article-sep">·</span>
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {updatedDate && (
          <>
            <span class="article-sep">·</span>
            <span>更新：{updatedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </>
        )}
      </p>
    </div>
  </section>

  <!-- Article Body + Sidebar -->
  <section class="article-layout">
    <div class="container">
      <div class="article-wrapper">
        <!-- Main Content -->
        <article class="article-content prose">
          {image && (
            <div class="article-featured-image">
              <img
                src={image}
                alt={title}
                loading="lazy"
                width="750"
                height="450"
              />
            </div>
          )}
          <slot />
        </article>

        <!-- Sticky Sidebar -->
        <aside class="article-sidebar">
          <div class="sidebar-sticky">
            <div class="sidebar-cta">
              <h3 class="sidebar-cta-title">有意訂製？</h3>
              <p class="sidebar-cta-desc">我們提供高品質手工木製家具的訂製服務，從設計到交付，全程職人把關。</p>
              <a href="https://www.facebook.com/RealFurnitureTW?utm_source=realfurniture.tw&utm_medium=cta&utm_campaign=contact&utm_content=sidebar" target="_blank" rel="noopener" class="btn btn-primary sidebar-cta-btn" data-track="cta-sidebar">聯繫我們</a>
            </div>

            <div class="sidebar-info">
              <div class="sidebar-info-item">
                <span class="sidebar-info-label">成立年份</span>
                <span class="sidebar-info-val font-mono">2018</span>
              </div>
              <div class="sidebar-info-item">
                <span class="sidebar-info-label">服務</span>
                <span class="sidebar-info-val">手工訂製</span>
              </div>
              <div class="sidebar-info-item">
                <span class="sidebar-info-label">地點</span>
                <span class="sidebar-info-val">台南永康區</span>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  {fallbackPosts.length > 0 && (
    <section class="related-section">
      <div class="container">
        <div class="related-header reveal">
          <p class="section-eyebrow">繼續閱讀</p>
          <h2 class="related-title">相關文章</h2>
        </div>
        <div class="related-grid">
          {fallbackPosts.map((post, i) => (
            <article class="post-card reveal" style={`transition-delay: ${i * 0.1}s`}>
              <a href={`/blog/${post.slug}`} class="post-card-link" aria-label={post.data.title}>
                <div class="post-card-image">
                  {post.data.image ? (
                    <img src={post.data.image} alt={post.data.title} loading="lazy" width="400" height="533" />
                  ) : (
                    <div class="post-card-placeholder">
                      <span class="post-card-placeholder-icon">木</span>
                    </div>
                  )}
                </div>
              </a>
              <div class="post-card-body">
                <div class="post-card-meta">
                  <span class="tag tag-wood">{post.data.category}</span>
                  <time class="post-card-date" datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('zh-TW')}
                  </time>
                </div>
                <h3 class="post-card-title">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h3>
                <p class="post-card-desc">{post.data.description}</p>
                <a href={`/blog/${post.slug}`} class="post-card-cta">閱讀全文 →</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ============================
     Article Hero
     ============================ */
  .article-hero {
    background-color: var(--color-cream);
    border-bottom: 1px solid var(--border-color);
    padding: var(--space-12) 0 var(--space-12);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .breadcrumb-link {
    font-size: var(--text-sm);
    color: var(--color-stone);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .breadcrumb-link:hover {
    color: var(--color-wood);
  }

  .breadcrumb-sep {
    color: var(--color-warm-gray);
    font-size: var(--text-sm);
  }

  .breadcrumb-current {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .article-meta-top {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }

  .article-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-charcoal);
    margin-bottom: var(--space-4);
    max-width: 750px;
  }

  .article-byline {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-stone);
    flex-wrap: wrap;
  }

  .article-author {
    font-weight: 500;
    color: var(--color-charcoal);
  }

  .article-sep {
    color: var(--color-warm-gray);
  }

  /* ============================
     Article Layout (Content + Sidebar)
     ============================ */
  .article-layout {
    padding: var(--space-16) 0;
  }

  .article-wrapper {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-16);
    align-items: start;
  }

  /* ============================
     Article Content
     ============================ */
  .article-content {
    max-width: 750px;
  }

  .article-featured-image {
    margin-bottom: var(--space-8);
    overflow: hidden;
  }

  .article-featured-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ============================
     Sidebar
     ============================ */
  .sidebar-sticky {
    position: sticky;
    top: calc(var(--nav-height-desktop) + var(--space-6));
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .sidebar-cta {
    background-color: var(--color-linen);
    border: 1px solid var(--border-color);
    padding: var(--space-6);
  }

  .sidebar-cta-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-charcoal);
    margin-bottom: var(--space-3);
  }

  .sidebar-cta-desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--color-stone);
    margin-bottom: var(--space-6);
  }

  .sidebar-cta-btn {
    width: 100%;
    text-align: center;
  }

  .sidebar-info {
    background-color: var(--color-cream);
    border: 1px solid var(--border-color);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .sidebar-info-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    font-size: var(--text-sm);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-color);
  }

  .sidebar-info-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .sidebar-info-label {
    color: var(--color-stone);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
  }

  .sidebar-info-val {
    color: var(--color-charcoal);
    font-weight: 500;
  }

  /* ============================
     Related Section
     ============================ */
  .related-section {
    background-color: var(--color-linen);
    padding: var(--space-16) 0;
  }

  .related-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .related-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-charcoal);
    margin-top: var(--space-2);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  /* Shared Post Card (mirrors index.astro) */
  .section-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-wood);
    margin-bottom: var(--space-2);
  }

  .post-card {
    background-color: var(--color-cream);
    border: 1px solid var(--border-color);
    overflow: hidden;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .post-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-3px);
  }

  .post-card-link {
    display: block;
    text-decoration: none;
  }

  .post-card-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: var(--color-linen);
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow);
  }

  .post-card:hover .post-card-image img {
    transform: scale(1.03);
  }

  .post-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-linen) 0%, var(--color-warm-gray) 100%);
    transition: transform var(--transition-slow);
  }

  .post-card:hover .post-card-placeholder {
    transform: scale(1.03);
  }

  .post-card-placeholder-icon {
    font-family: var(--font-heading);
    font-size: 3rem;
    color: rgba(44, 40, 36, 0.2);
  }

  .post-card-body {
    padding: var(--space-6);
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .post-card-date {
    font-size: var(--text-xs);
    color: var(--color-stone);
  }

  .post-card-title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: var(--space-3);
  }

  .post-card-title a {
    color: var(--color-charcoal);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .post-card-title a:hover {
    color: var(--color-wood);
  }

  .post-card-desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--color-stone);
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-cta {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-wood);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .post-card-cta:hover {
    color: var(--color-wood-dark);
  }

  /* ============================
     Responsive
     ============================ */
  @media (max-width: 1024px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .article-wrapper {
      grid-template-columns: 1fr;
    }

    .article-sidebar {
      order: -1;
    }

    .sidebar-sticky {
      position: static;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
