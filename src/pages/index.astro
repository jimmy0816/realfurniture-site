---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="里爾家具研究室"
  description="台灣高級木製傢俱深度評測與選購指南。從實木餐桌到手工木椅，我們用專業眼光替你把關每一件家中珍品。"
>
  <!-- ============================
       Hero Section
       ============================ -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content container">
      <p class="hero-eyebrow">Taiwan Fine Furniture</p>
      <h1 class="hero-title">每一件家具，<br />都是一次與木的對話</h1>
      <p class="hero-subtitle">台灣高級木製傢俱的深度研究基地<br />用職人眼光，替你找到值得傳家的每一件木作</p>
      <div class="hero-actions">
        <a href="/blog" class="btn btn-primary">探索文章</a>
        <a href="https://www.facebook.com/RealFurnitureTW?utm_source=realfurniture.tw&utm_medium=cta&utm_campaign=contact&utm_content=hero" target="_blank" rel="noopener" class="btn btn-outline" data-track="cta-hero">聯繫我們</a>
      </div>
    </div>
    <div class="hero-scroll-hint" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <!-- ============================
       Brand Introduction
       ============================ -->
  <section class="brand-section reveal">
    <div class="container">
      <div class="brand-grid">
        <!-- Left: Heading -->
        <div class="brand-left">
          <p class="section-eyebrow">關於我們</p>
          <h2 class="brand-heading">以職人之眼，<br />丈量每一件木作</h2>
          <div class="brand-stats">
            <div class="stat-item reveal">
              <span class="stat-num">2018</span>
              <span class="stat-label">成立年份</span>
            </div>
            <div class="stat-item reveal">
              <span class="stat-num">手工</span>
              <span class="stat-label">訂製家具</span>
            </div>
            <div class="stat-item reveal">
              <span class="stat-num">永康</span>
              <span class="stat-label">台南永康區</span>
            </div>
          </div>
        </div>

        <!-- Right: Content -->
        <div class="brand-right reveal">
          <p class="brand-text">
            里爾家具研究室成立於 2018 年，座落於台南永康，是台灣少數深耕高級木製家具評測的專業平台。
          </p>
          <p class="brand-text">
            我們相信，一件好家具不只是功能性的物品，它是工匠與木材之間的對話結晶——木的紋理記載著歲月，榫卯的精密折射著工藝的溫度。
          </p>
          <p class="brand-text">
            從實木餐桌的選材標準，到手工榫卯的製作工序，我們用最嚴謹的視角，為你解析每一件木作的真實價值。
          </p>
          <a href="/blog" class="brand-link">閱讀更多文章 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       Latest Posts
       ============================ -->
  <section class="posts-section">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-eyebrow">最新內容</p>
        <h2 class="section-title">精選文章</h2>
      </div>

      {posts.length === 0 ? (
        <p class="posts-empty">文章整理中，敬請期待...</p>
      ) : (
        <div class="posts-grid">
          {posts.map((post, i) => (
            <article class="post-card reveal" style={`transition-delay: ${i * 0.1}s`}>
              <a href={`/blog/${post.slug}`} class="post-card-link" aria-label={post.data.title}>
                <div class="post-card-image">
                  {post.data.image ? (
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      loading="lazy"
                      width="400"
                      height="533"
                    />
                  ) : (
                    <div class="post-card-placeholder">
                      <span class="post-card-placeholder-icon">木</span>
                    </div>
                  )}
                </div>
              </a>
              <div class="post-card-body">
                <div class="post-card-meta">
                  <span class="tag tag-wood">{post.data.category}</span>
                  <time class="post-card-date" datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
                <h3 class="post-card-title">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h3>
                <p class="post-card-desc">{post.data.description}</p>
                <a href={`/blog/${post.slug}`} class="post-card-cta">閱讀全文 →</a>
              </div>
            </article>
          ))}
        </div>
      )}

      <div class="posts-more reveal">
        <a href="/blog" class="btn btn-primary">查看所有文章</a>
      </div>
    </div>
  </section>

  <!-- ============================
       CTA Banner
       ============================ -->
  <section class="cta-banner reveal">
    <div class="cta-inner container">
      <div class="cta-content">
        <h2 class="cta-title">尋找屬於你的木作傳家品</h2>
        <p class="cta-desc">每一件手工家具，都值得被認識。讓我們帶你認識台灣木作工藝的精粹。</p>
      </div>
      <div class="cta-actions">
        <a href="/blog" class="btn btn-outline">瀏覽我們的作品</a>
        <a href="https://www.facebook.com/RealFurnitureTW?utm_source=realfurniture.tw&utm_medium=cta&utm_campaign=contact&utm_content=banner" target="_blank" rel="noopener" class="btn" style="background-color: var(--color-cream); color: var(--color-wood-dark);" data-track="cta-banner">聯繫我們</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================
     Hero
     ============================ */
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-charcoal) 0%, var(--color-ink) 100%);
    /* Reserve for future image: background-image: url('/hero.webp'); background-size: cover; */
    z-index: 0;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(26, 23, 20, 0.6) 0%, rgba(26, 23, 20, 0.2) 60%, transparent 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: var(--space-24);
    padding-bottom: var(--space-24);
  }

  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-wood-light);
    margin-bottom: var(--space-6);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-parchment);
    margin-bottom: var(--space-6);
    max-width: 700px;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    line-height: 1.9;
    color: var(--color-warm-gray);
    margin-bottom: var(--space-12);
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }

  .hero-scroll-hint span {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--color-wood-light), transparent);
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0% { opacity: 0; transform: scaleY(0); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); transform-origin: top; }
    100% { opacity: 0; transform: scaleY(1); transform-origin: bottom; }
  }

  /* ============================
     Section Common
     ============================ */
  .section-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-wood);
    margin-bottom: var(--space-3);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-charcoal);
  }

  /* ============================
     Brand Section
     ============================ */
  .brand-section {
    padding: var(--space-24) 0;
    border-bottom: 1px solid var(--border-color);
  }

  .brand-grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-16);
    align-items: start;
  }

  .brand-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--color-charcoal);
    line-height: 1.25;
    margin-top: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .brand-stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    border-left: 2px solid var(--color-wood-light);
    padding-left: var(--space-6);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat-num {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: 500;
    color: var(--color-wood);
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    color: var(--color-stone);
  }

  .brand-text {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.9;
    color: var(--color-charcoal);
    margin-bottom: var(--space-4);
  }

  .brand-link {
    display: inline-block;
    margin-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-wood);
    letter-spacing: 0.04em;
    text-decoration: none;
    border-bottom: 1px solid var(--color-wood-light);
    padding-bottom: 2px;
    transition: color var(--transition-base), border-color var(--transition-base);
  }

  .brand-link:hover {
    color: var(--color-wood-dark);
    border-color: var(--color-wood);
  }

  /* ============================
     Posts Section
     ============================ */
  .posts-section {
    padding: var(--space-24) 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  .posts-empty {
    text-align: center;
    color: var(--color-stone);
    padding: var(--space-16) 0;
    font-size: var(--text-lg);
  }

  .post-card {
    background-color: var(--color-cream);
    border: 1px solid var(--border-color);
    overflow: hidden;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .post-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-3px);
  }

  .post-card-link {
    display: block;
    text-decoration: none;
  }

  .post-card-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: var(--color-linen);
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow);
  }

  .post-card:hover .post-card-image img {
    transform: scale(1.03);
  }

  .post-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-linen) 0%, var(--color-warm-gray) 100%);
    transition: transform var(--transition-slow);
  }

  .post-card:hover .post-card-placeholder {
    transform: scale(1.03);
  }

  .post-card-placeholder-icon {
    font-family: var(--font-heading);
    font-size: 3rem;
    color: rgba(44, 40, 36, 0.2);
  }

  .post-card-body {
    padding: var(--space-6);
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .post-card-date {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-stone);
  }

  .post-card-title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: var(--space-3);
  }

  .post-card-title a {
    color: var(--color-charcoal);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .post-card-title a:hover {
    color: var(--color-wood);
  }

  .post-card-desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--color-stone);
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-cta {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-wood);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .post-card-cta:hover {
    color: var(--color-wood-dark);
  }

  .posts-more {
    text-align: center;
  }

  /* ============================
     CTA Banner
     ============================ */
  .cta-banner {
    background-color: var(--color-wood);
    padding: var(--space-16) 0;
    margin-top: var(--space-16);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--color-parchment);
    margin-bottom: var(--space-3);
  }

  .cta-desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: rgba(247, 243, 236, 0.75);
    max-width: 500px;
    line-height: 1.7;
  }

  .cta-actions {
    display: flex;
    gap: var(--space-4);
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  /* ============================
     Responsive
     ============================ */
  @media (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .brand-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .brand-stats {
      flex-direction: row;
      border-left: none;
      border-top: 2px solid var(--color-wood-light);
      padding-left: 0;
      padding-top: var(--space-6);
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .cta-inner {
      flex-direction: column;
      text-align: center;
    }

    .cta-actions {
      justify-content: center;
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
