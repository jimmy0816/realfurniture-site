---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map(p => p.data.category))];
  return categories.map(cat => ({
    params: { category: cat },
    props: {
      posts: posts.filter(p => p.data.category === cat),
      allPosts: posts,
    }
  }));
}

const { category } = Astro.params;
const { posts, allPosts } = Astro.props;
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Popular/recent posts for sidebar (top 5 by date)
const popularPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

// All categories for filter
const categories = [...new Set(allPosts.map(p => p.data.category))];
---

<BaseLayout
  title={`${category} — 文章列表`}
  description={`里爾家具研究室 ${category} 分類文章。深度探索台灣高級木製家具的工藝與美學。`}
>
  <!-- Page Header -->
  <section class="category-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="麵包屑導航">
        <a href="/" class="breadcrumb-link">首頁</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/categories" class="breadcrumb-link">分類</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{category}</span>
      </nav>
      <p class="section-eyebrow">文章分類</p>
      <h1 class="category-title">{category}</h1>
      <p class="category-count">{sorted.length} 篇文章</p>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="category-filter-bar">
    <div class="container">
      <div class="filter-scroll">
        <a href="/categories" class="filter-chip">全部分類</a>
        {categories.map(cat => (
          <a
            href={`/categories/${cat}`}
            class={`filter-chip ${cat === category ? 'active' : ''}`}
          >
            {cat}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Main Content + Sidebar -->
  <section class="category-layout">
    <div class="container">
      <div class="category-wrapper">
        <!-- Posts Grid -->
        <main class="posts-main">
          {sorted.length === 0 ? (
            <div class="posts-empty">
              <p>此分類暫無文章，請稍後再來。</p>
              <a href="/blog" class="btn btn-primary" style="margin-top: 1.5rem;">查看所有文章</a>
            </div>
          ) : (
            <div class="posts-grid">
              {sorted.map((post, i) => (
                <article class="post-card reveal" style={`transition-delay: ${(i % 3) * 0.1}s`}>
                  <a href={`/blog/${post.slug}`} class="post-card-image-link" aria-label={post.data.title}>
                    <div class="post-card-image">
                      {post.data.image ? (
                        <img
                          src={post.data.image}
                          alt={post.data.title}
                          loading="lazy"
                          width="400"
                          height="300"
                        />
                      ) : (
                        <div class="post-card-placeholder">
                          <span class="placeholder-char">木</span>
                        </div>
                      )}
                    </div>
                  </a>
                  <div class="post-card-body">
                    <div class="post-card-meta">
                      <span class="tag tag-wood">{post.data.category}</span>
                      <time datetime={post.data.pubDate.toISOString()} class="post-date">
                        {post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
                      </time>
                    </div>
                    <h2 class="post-card-title">
                      <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                    </h2>
                    <p class="post-card-desc">{post.data.description}</p>
                    <div class="post-card-tags">
                      {post.data.tags.slice(0, 3).map(tag => (
                        <span class="tag">#{tag}</span>
                      ))}
                    </div>
                    <a href={`/blog/${post.slug}`} class="post-card-cta">閱讀全文 →</a>
                  </div>
                </article>
              ))}
            </div>
          )}
        </main>

        <!-- Sidebar -->
        <aside class="posts-sidebar">
          <div class="sidebar-sticky">
            <!-- Popular Posts -->
            <div class="sidebar-widget">
              <h3 class="sidebar-widget-title">最新文章</h3>
              <ul class="sidebar-post-list">
                {popularPosts.map(post => (
                  <li class="sidebar-post-item">
                    <a href={`/blog/${post.slug}`} class="sidebar-post-link">
                      <span class="sidebar-post-title">{post.data.title}</span>
                      <time class="sidebar-post-date" datetime={post.data.pubDate.toISOString()}>
                        {post.data.pubDate.toLocaleDateString('zh-TW', { month: 'long', day: 'numeric' })}
                      </time>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <!-- All Categories -->
            <div class="sidebar-widget">
              <h3 class="sidebar-widget-title">所有分類</h3>
              <ul class="sidebar-cat-list">
                {categories.map(cat => (
                  <li class="sidebar-cat-item">
                    <a
                      href={`/categories/${cat}`}
                      class={`sidebar-cat-link ${cat === category ? 'active' : ''}`}
                    >
                      {cat}
                      <span class="sidebar-cat-count">
                        {allPosts.filter(p => p.data.category === cat).length}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <!-- CTA -->
            <div class="sidebar-cta">
              <p class="sidebar-cta-text">有意訂製木製家具？</p>
              <a href="https://www.facebook.com/RealFurnitureTW?utm_source=realfurniture.tw&utm_medium=cta&utm_campaign=contact&utm_content=category-sidebar" target="_blank" rel="noopener" class="btn btn-primary sidebar-cta-btn" data-track="cta-category-sidebar">聯繫我們</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================
     Category Hero
     ============================ */
  .category-hero {
    background-color: var(--color-cream);
    border-bottom: 1px solid var(--border-color);
    padding: var(--space-12) 0 var(--space-8);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .breadcrumb-link {
    font-size: var(--text-sm);
    color: var(--color-stone);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .breadcrumb-link:hover {
    color: var(--color-wood);
  }

  .breadcrumb-sep {
    color: var(--color-warm-gray);
    font-size: var(--text-sm);
  }

  .breadcrumb-current {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
  }

  .section-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-wood);
    margin-bottom: var(--space-2);
  }

  .category-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-charcoal);
    margin-bottom: var(--space-3);
  }

  .category-count {
    font-size: var(--text-sm);
    color: var(--color-stone);
  }

  /* ============================
     Filter Bar
     ============================ */
  .category-filter-bar {
    background-color: var(--color-parchment);
    border-bottom: 1px solid var(--border-color);
    padding: var(--space-4) 0;
    position: sticky;
    top: var(--nav-height-desktop);
    z-index: 50;
  }

  .filter-scroll {
    display: flex;
    gap: var(--space-2);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 2px;
  }

  .filter-scroll::-webkit-scrollbar {
    display: none;
  }

  .filter-chip {
    display: inline-block;
    padding: 0.375rem 1rem;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--color-stone);
    background-color: transparent;
    border: 1px solid var(--border-color);
    border-radius: 0;
    text-decoration: none;
    white-space: nowrap;
    transition: all var(--transition-base);
    flex-shrink: 0;
  }

  .filter-chip:hover {
    color: var(--color-charcoal);
    border-color: var(--color-stone);
  }

  .filter-chip.active {
    background-color: var(--color-wood);
    color: var(--color-parchment);
    border-color: var(--color-wood);
  }

  /* ============================
     Layout
     ============================ */
  .category-layout {
    padding: var(--space-12) 0 var(--space-24);
  }

  .category-wrapper {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-12);
    align-items: start;
  }

  /* ============================
     Posts Grid
     ============================ */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }

  .posts-empty {
    text-align: center;
    padding: var(--space-24) 0;
    color: var(--color-stone);
    font-size: var(--text-lg);
  }

  /* Post Card */
  .post-card {
    background-color: var(--color-cream);
    border: 1px solid var(--border-color);
    overflow: hidden;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .post-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-3px);
  }

  .post-card-image-link {
    display: block;
    text-decoration: none;
  }

  .post-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-linen);
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow);
  }

  .post-card:hover .post-card-image img {
    transform: scale(1.03);
  }

  .post-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-linen), var(--color-warm-gray));
    transition: transform var(--transition-slow);
  }

  .post-card:hover .post-card-placeholder {
    transform: scale(1.03);
  }

  .placeholder-char {
    font-family: var(--font-heading);
    font-size: 3rem;
    color: rgba(44, 40, 36, 0.2);
  }

  .post-card-body {
    padding: var(--space-6);
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .post-date {
    font-size: var(--text-xs);
    color: var(--color-stone);
  }

  .post-card-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: var(--space-3);
  }

  .post-card-title a {
    color: var(--color-charcoal);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .post-card-title a:hover {
    color: var(--color-wood);
  }

  .post-card-desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--color-stone);
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }

  .post-card-cta {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-wood);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .post-card-cta:hover {
    color: var(--color-wood-dark);
  }

  /* ============================
     Sidebar
     ============================ */
  .sidebar-sticky {
    position: sticky;
    top: calc(var(--nav-height-desktop) + 56px + var(--space-6));
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .sidebar-widget {
    background-color: var(--color-cream);
    border: 1px solid var(--border-color);
    padding: var(--space-6);
  }

  .sidebar-widget-title {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-stone);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-color);
  }

  .sidebar-post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sidebar-post-item {
    border-bottom: 1px solid var(--border-color);
  }

  .sidebar-post-item:last-child {
    border-bottom: none;
  }

  .sidebar-post-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) 0;
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .sidebar-post-title {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--transition-base);
  }

  .sidebar-post-link:hover .sidebar-post-title {
    color: var(--color-wood);
  }

  .sidebar-post-date {
    font-size: var(--text-xs);
    color: var(--color-stone);
  }

  .sidebar-cat-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sidebar-cat-item {
    border-bottom: 1px solid var(--border-color);
  }

  .sidebar-cat-item:last-child {
    border-bottom: none;
  }

  .sidebar-cat-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) 0;
    font-size: var(--text-sm);
    color: var(--color-stone);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .sidebar-cat-link:hover,
  .sidebar-cat-link.active {
    color: var(--color-wood);
  }

  .sidebar-cat-count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-warm-gray);
    background-color: var(--color-linen);
    padding: 2px 6px;
  }

  .sidebar-cta {
    background-color: var(--color-linen);
    border: 1px solid var(--border-color);
    padding: var(--space-6);
    text-align: center;
  }

  .sidebar-cta-text {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    color: var(--color-charcoal);
    margin-bottom: var(--space-4);
    line-height: 1.5;
  }

  .sidebar-cta-btn {
    width: 100%;
    text-align: center;
  }

  /* ============================
     Responsive
     ============================ */
  @media (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .category-wrapper {
      grid-template-columns: 1fr;
    }

    .posts-sidebar {
      order: -1;
    }

    .sidebar-sticky {
      position: static;
    }

    .category-filter-bar {
      top: var(--nav-height-mobile);
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
